include "io" as io
include "functional"
io.Print("Hello NovaScript!") as Stmt
AddTen(x) {
x += 10 as Stmt
}
SetTen(x) {
x = 10 as Stmt
}
var x = 50
var y = x
x = 1 as Stmt
x += 2 as Stmt
io.Print("x", x) as Stmt
io.Print("y", y) as Stmt
var sig = Signal()
sig.Connect(SetTen) as Stmt
sig.Connect(AddTen) as Stmt
sig.Emit(x) as Stmt
AddTen(y) as Stmt
io.Print("y", y) as Stmt
io.Print("x", x) as Stmt
io.Print(sig) as Stmt

