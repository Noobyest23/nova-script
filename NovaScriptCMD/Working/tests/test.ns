include "io" as io
include "functional"
include "math" as math
include "types"

io.Print("Hello NovaScript!")

func AddTen(x) {
	x += 10
}

func SetTen(x) {
	x = 10
}
var x = 50
var y = x
x = 1
x += 2
io.Print("x", x)
io.Print("y", y)

var sig = Signal()
sig.Connect(SetTen)
sig.Connect(AddTen)

for function in sig.GetConnections() {
	function(1)
}

for (Eep in [1, 2, 3]) {
	io.Print("bangalangadooda", Eep)
}

io.Print(math.RandF())

io.Print([1, 2, 3, 4, 5, 6, 7].Size())

if (1 is "Int") {
	io.Print("Yippee")
}

io.Print(Float("10"));