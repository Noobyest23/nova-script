include "io" as io
include "signal"

var input_number = io.Input("Enter how many erics you would like to explode")
var i = Int(input_number)


func for_i(sig, i)
{
    sig.Emit(i)
    if i > 0
    {
        for_i(sig, i - 1)
    }
}

func explode_eric(i)
{
    io.Print(i)
    #WriteFile("TestFile", "Contents") # for_i -> sig.Emit -> explode_eric -> WriteFile
}
var s = Signal()
s.Connect(explode_eric)
for_i(s, i - 1)